# Order Management 환경변수

# Railway PostgreSQL 연결 (새 프로젝트)
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:PORT/railway

# Flask 설정
SECRET_KEY=your-secret-key-here
DEBUG=False

# API 인증 (빈 값이면 인증 비활성화, 값을 설정하면 X-API-Key 헤더 필요)
API_KEY=

# CORS 허용 도메인 (콤마 구분, *는 전체 허용)
CORS_ORIGINS=*

# 로그 레벨 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
